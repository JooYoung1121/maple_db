# Stage 1: Next.js 빌드 (Node 20 slim - glibc 필요 for Tailwind v4 oxide)
FROM node:20-slim AS web-build
WORKDIR /app
COPY web/package.json web/package-lock.json* ./
RUN rm -rf node_modules package-lock.json && npm install
COPY web/ ./
ENV NEXT_PUBLIC_API_URL=""
RUN npm run build

# Stage 2: 최종 이미지 (Python + Node)
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Python 의존성
COPY crawler/requirements.txt crawler/requirements.txt
COPY api/requirements.txt api/requirements.txt
RUN pip install --no-cache-dir -r crawler/requirements.txt -r api/requirements.txt

# Next.js standalone 복사 (빌드된 결과물)
COPY --from=web-build /app/.next/standalone web-standalone
COPY --from=web-build /app/.next/static web-standalone/.next/static
COPY --from=web-build /app/public web-standalone/public

# 소스 복사
COPY crawler/ crawler/
COPY api/ api/

# 데이터 디렉토리 + DB
RUN mkdir -p data/cache
COPY data/maple.db* data/
RUN python -c "from crawler.db import init_db; init_db()"

# 시작 스크립트
COPY start.sh .
RUN chmod +x start.sh

EXPOSE 3000

CMD ["./start.sh"]
